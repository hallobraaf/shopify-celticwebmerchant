{%- comment -%}
  ============================================================================
  MAIN-ACCOUNT-LOGIN
  ============================================================================
  Login form with password recovery.
  Includes optional Shop Pay login and guest checkout.
  Displays on /account/login.
  ============================================================================
{%- endcomment -%}

{{ 'main-account-login.min.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }}.main-account-login {
    --account-error: #dc2626;
    --account-success: #16a34a;
    {%- if section.settings.background_color != blank %}
    --account-background: {{ section.settings.background_color }};
    background-color: {{ section.settings.background_color }};
    {%- endif %}
    {%- if section.settings.text_color != blank %}
    --account-text: {{ section.settings.text_color }};
    --account-border: {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    color: {{ section.settings.text_color }};
    {%- endif %}
    padding-block: {{ section.settings.padding_block }}em;
  }
{% endstyle %}

<div
  class="main-account-login__container {{ section.settings.width }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}
>
  {%- comment -%} Recover password form {%- endcomment -%}
  <div id="recover" class="main-account-login__recover" tabindex="-1">
    <h1 class="main-account-login__title">{{ 'customer.recover_password.title' | t }}</h1>
    <p class="main-account-login__subtitle">{{ 'customer.recover_password.subtext' | t }}</p>

    {%- form 'recover_customer_password', class: 'main-account-login__form' -%}
      {%- assign recover_success = form.posted_successfully? -%}

      {%- if form.errors -%}
        <div class="main-account-login__errors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span>{{ form.errors.messages.form }}</span>
        </div>
      {%- endif -%}

      <div class="main-account-login__field">
        <label for="RecoverEmail" class="main-account-login__label">{{ 'customer.login_page.email' | t }}</label>
        <input
          type="email"
          name="email"
          id="RecoverEmail"
          class="main-account-login__input"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}aria-invalid="true" aria-describedby="RecoverEmail-error" autofocus{% endif %}
        >
      </div>

      <button type="submit" class="main-account-login__submit">
        {{ 'customer.login_page.submit' | t }}
      </button>

      <a href="#login" class="main-account-login__link main-account-login__link--center">
        {{ 'customer.login_page.cancel' | t }}
      </a>
    {%- endform -%}
  </div>

  {%- comment -%} Login form {%- endcomment -%}
  <div id="login" class="main-account-login__login" tabindex="-1">
    <h1 class="main-account-login__title">{{ 'customer.login_page.title' | t }}</h1>

    {%- if recover_success == true -%}
      <div class="main-account-login__success" tabindex="-1" autofocus>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>{{ 'customer.recover_password.success' | t }}</span>
      </div>
    {%- endif -%}

    {%- form 'customer_login', novalidate: 'novalidate', class: 'main-account-login__form' -%}
      {%- if form.errors -%}
        <div class="main-account-login__errors" tabindex="-1" autofocus>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span>{{ 'templates.contact.form.error_heading' | t }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.enable_shop_login and shop.features.login_with_shop_classic_customer_accounts? -%}
        <div class="main-account-login__shop-login">
          {{ shop | login_button }}
        </div>
        <div class="main-account-login__divider">
          <span>{{ 'customer.login_page.alternate_provider_separator' | t }}</span>
        </div>
      {%- endif -%}

      <div class="main-account-login__field">
        <label for="CustomerEmail" class="main-account-login__label">{{ 'customer.login_page.email' | t }}</label>
        <input
          type="email"
          name="customer[email]"
          id="CustomerEmail"
          class="main-account-login__input"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          {% if form.errors contains 'form' %}aria-invalid="true"{% endif %}
        >
      </div>

      {%- if form.password_needed -%}
        <div class="main-account-login__field">
          <label for="CustomerPassword" class="main-account-login__label">{{ 'customer.login_page.password' | t }}</label>
          <input
            type="password"
            name="customer[password]"
            id="CustomerPassword"
            class="main-account-login__input"
            autocomplete="current-password"
            {% if form.errors contains 'form' %}aria-invalid="true"{% endif %}
          >
        </div>

        <a href="#recover" class="main-account-login__link">
          {{ 'customer.login_page.forgot_password' | t }}
        </a>
      {%- endif -%}

      <button type="submit" class="main-account-login__submit">
        {{ 'customer.login_page.sign_in' | t }}
      </button>

      <p class="main-account-login__register-link">
        {{ 'customer.login_page.new_customer' | t }}
        <a href="{{ routes.account_register_url }}">{{ 'customer.login_page.create_account' | t }}</a>
      </p>
    {%- endform -%}

    {%- if shop.checkout.guest_login -%}
      <div class="main-account-login__guest">
        <div class="main-account-login__divider">
          <span>{{ 'customer.login_page.or' | t }}</span>
        </div>
        <h2 class="main-account-login__guest-title">{{ 'customer.login_page.guest_title' | t }}</h2>
        {%- form 'guest_login' -%}
          <button type="submit" class="main-account-login__guest-button">
            {{ 'customer.login_page.guest_continue' | t }}
          </button>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Account login",
  "tag": "section",
  "class": "main-account-login",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "enable_shop_login",
      "label": "Enable Shop Pay login button",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "text",
      "id": "anchor",
      "label": "Anchor ID",
      "info": "ID for scroll links (without #)."
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "is-align-narrow", "label": "Narrow" },
        { "value": "is-align-small", "label": "Small" },
        { "value": "is-align", "label": "Regular" },
        { "value": "is-align-wide", "label": "Wide" },
        { "value": "is-align-full", "label": "Full" }
      ],
      "default": "is-align-full"
    },
    {
      "type": "range",
      "id": "padding_block",
      "label": "Vertical padding",
      "min": 0,
      "max": 6,
      "step": 0.5,
      "default": 4,
      "unit": "em"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Howto"
    },
    {
      "type": "paragraph",
      "content": "Login form with password recovery. Includes optional Shop Pay login and guest checkout options."
    }
  ]
}
{% endschema %}
