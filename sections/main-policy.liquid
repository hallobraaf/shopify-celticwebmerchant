{%- comment -%}
  ============================================================================
  MAIN-POLICY
  ============================================================================
  Policy page content section. Auto-detects which policy to show based on URL.
  Content is managed in Settings > Policies.

  Available policies:
  /policies/privacy-policy, /policies/refund-policy,
  /policies/terms-of-service, /policies/shipping-policy,
  /policies/subscription-policy, /policies/legal-notice,
  /policies/contact-information
  ============================================================================
{%- endcomment -%}

{{ 'main-policy.min.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_policy = nil
  for policy in shop.policies
    if request.path contains policy.url
      assign current_policy = policy
      break
    endif
  endfor
-%}

{%- if current_policy != blank -%}
  <div class="main-policy__content is-align">
    <h1 class="main-policy__title">{{ current_policy.title }}</h1>
    <div class="main-policy__body rte">
      {{ current_policy.body }}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Policy content",
  "tag": "section",
  "class": "main-policy",
  "settings": [
    {
      "type": "header",
      "content": "Howto"
    },
    {
      "type": "paragraph",
      "content": "Displays policy content based on URL. Content is managed in Settings > Policies."
    }
  ]
}
{% endschema %}
