{%- comment -%}
  ============================================================================
  BLOCK-MODAL-REGION
  ============================================================================

  Purpose:
  Modal for selecting language/region preferences.
  Supports three optional levels via block types:
  - "group"    block: main heading (e.g. "Europa") — optional
  - "region"   block: sub-heading row (e.g. "Nederland")
  - "language" block: inline pill belonging to the preceding region

  All levels are optional and can be mixed freely:
  - Flat:    Region → Language → Language
  - Grouped: Group → Region → Language → Region → Language

  Switching locale uses Shopify's native localization form, which correctly
  handles translated URLs and preserves the current page path across all
  markets and domains (.com, .co.uk).

  Active state is determined by matching country_code + language_code
  against Shopify's localization object.

  Usage:
  Add to footer-group.json. Trigger with data-modal-trigger="region-modal".

  Dependencies:
  - theme-modal.js
  - theme-ux.css
  - html-theme-icons snippet

  ============================================================================
{%- endcomment -%}

{%- liquid
  assign show_trigger     = section.settings.show_trigger
  assign modal_id         = section.settings.modal_id | default: 'region-modal'
  assign current_country  = localization.country.iso_code | downcase
  assign current_language = localization.language.iso_code | downcase
-%}

{%- comment -%} Trigger Button {%- endcomment -%}
{%- if show_trigger -%}
  <button
    type="button"
    class="block-modal-region__trigger"
    aria-haspopup="dialog"
    data-modal-trigger="{{ modal_id }}"
  >
    <span class="block-modal-region__trigger-icon" aria-hidden="true">
      {%- render 'html-theme-icons', icon: 'globe', size: 20 -%}
    </span>
    <span class="block-modal-region__trigger-text">
      {{ localization.language.endonym_name | capitalize }} | {{ localization.country.iso_code }}
    </span>
  </button>
{%- endif -%}

{%- comment -%} Modal {%- endcomment -%}
<div
  data-modal="{{ modal_id }}"
  id="{{ modal_id }}"
  role="dialog"
  aria-modal="true"
  aria-labelledby="{{ modal_id }}-title"
  hidden
>
  <div data-modal-overlay></div>

  <div class="theme-modal__content block-modal-region__content">
    <header class="theme-modal__header">
      <h2 class="theme-modal__title" id="{{ modal_id }}-title">
        {{ 'localization.modal_heading' | t }}
      </h2>
      <button
        type="button"
        class="theme-modal__close"
        data-modal-close
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {%- render 'html-theme-icons', icon: 'close', size: 20 -%}
      </button>
    </header>

    <div class="theme-modal__body">

      {%- comment -%} Hidden form — submitted via JS on language click {%- endcomment -%}
      {%- form 'localization', id: modal_id, class: 'block-modal-region__form' -%}
        <input type="hidden" id="{{ modal_id }}-country-code"  name="country_code"  value="{{ current_country }}">
        <input type="hidden" id="{{ modal_id }}-language-code" name="language_code" value="{{ current_language }}">
      {%- endform -%}

      {%- if section.blocks.size > 0 -%}
        <div class="block-modal-region__markets">
          {%- liquid
            assign in_group  = false
            assign in_market = false
          -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- when 'group' -%}
                {%- comment -%} Close open region + group {%- endcomment -%}
                {%- if in_market -%}</div></div>{%- assign in_market = false -%}{%- endif -%}
                {%- if in_group -%}</div>{%- assign in_group = false -%}{%- endif -%}
                {%- assign in_group = true -%}
                <div class="block-modal-region__group" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <p class="block-modal-region__group-name">{{ block.settings.title }}</p>
                  {%- endif -%}

              {%- when 'region' -%}
                {%- comment -%} Close open region only {%- endcomment -%}
                {%- if in_market -%}</div></div>{%- endif -%}
                {%- assign in_market = true -%}
                <div class="block-modal-region__market" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <p class="block-modal-region__market-name">{{ block.settings.title }}</p>
                  {%- endif -%}
                  <div class="block-modal-region__languages">

              {%- when 'language' -%}
                {%- liquid
                  assign lang_label    = block.settings.label
                  assign lang_country  = block.settings.country_code
                  assign lang_language = block.settings.language_code
                  assign is_active     = false
                  if lang_country == current_country and lang_language == current_language
                    assign is_active = true
                  endif
                -%}
                {%- if lang_label != blank and lang_country != blank and lang_language != blank -%}
                  {%- if is_active -%}
                    <span
                      class="block-modal-region__lang-btn is-active"
                      aria-current="true"
                      {{ block.shopify_attributes }}
                    >{{ lang_label }}</span>
                  {%- else -%}
                    <button
                      type="button"
                      class="block-modal-region__lang-btn"
                      data-region-country="{{ lang_country }}"
                      data-region-language="{{ lang_language }}"
                      data-region-form="{{ modal_id }}"
                      {{ block.shopify_attributes }}
                    >{{ lang_label }}</button>
                  {%- endif -%}
                {%- endif -%}

            {%- endcase -%}
          {%- endfor -%}

          {%- comment -%} Close remaining open tags {%- endcomment -%}
          {%- if in_market -%}</div></div>{%- endif -%}
          {%- if in_group -%}</div>{%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_info_text -%}
        <p class="block-modal-region__info">
          {{ 'localization.info_text' | t }}
        </p>
      {%- endif -%}

    </div>
  </div>
</div>

<script>
  (function() {
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-region-form]');
      if (!btn) return;

      var formId   = btn.dataset.regionForm;
      var country  = btn.dataset.regionCountry;
      var language = btn.dataset.regionLanguage;
      var form     = document.getElementById(formId);
      if (!form) return;

      form.querySelector('#' + formId + '-country-code').value  = country;
      form.querySelector('#' + formId + '-language-code').value = language;
      form.submit();
    });
  })();
</script>

{{ 'block-modal-region.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Region modal",
  "tag": "section",
  "class": "block-modal-region",
  "limit": 1,
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_trigger",
      "label": "Show trigger button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_info_text",
      "label": "Show info text",
      "default": true
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "modal_id",
      "label": "Modal ID",
      "default": "region-modal"
    },
    {
      "type": "header",
      "content": "Howto"
    },
    {
      "type": "paragraph",
      "content": "Flat: Region → Language → Language. Grouped: Group → Region → Language → Region → Language. Group is optional."
    }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Group",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "placeholder": "Europa"
        }
      ]
    },
    {
      "type": "region",
      "name": "Region",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "placeholder": "Nederland"
        }
      ]
    },
    {
      "type": "language",
      "name": "Language",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "placeholder": "Nederlands"
        },
        {
          "type": "text",
          "id": "language_code",
          "label": "Language code",
          "placeholder": "nl",
          "info": "Lowercase. e.g. nl, de, fr, en"
        },
        {
          "type": "text",
          "id": "country_code",
          "label": "Country code",
          "placeholder": "nl",
          "info": "Lowercase. e.g. nl, be, de, fr, gb"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Region modal",
      "category": "Modal",
      "blocks": [
        { "type": "group",    "settings": { "title": "Europa" } },
        { "type": "region",   "settings": { "title": "Nederland" } },
        { "type": "language", "settings": { "label": "Nederlands", "language_code": "nl", "country_code": "nl" } },
        { "type": "language", "settings": { "label": "English",    "language_code": "en", "country_code": "nl" } },
        { "type": "region",   "settings": { "title": "Belgi\u00eb" } },
        { "type": "language", "settings": { "label": "Nederlands", "language_code": "nl", "country_code": "be" } },
        { "type": "language", "settings": { "label": "Fran\u00e7ais",   "language_code": "fr", "country_code": "be" } },
        { "type": "group",    "settings": { "title": "Overig" } },
        { "type": "region",   "settings": { "title": "United Kingdom" } },
        { "type": "language", "settings": { "label": "English",    "language_code": "en", "country_code": "gb" } }
      ]
    }
  ]
}
{% endschema %}
