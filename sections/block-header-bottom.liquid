{%- assign menu = linklists[section.settings.menu] -%}
{%- liquid
	assign assist_link_text = section.settings.assist_link_text
	if assist_link_text == blank
		assign assist_link_text = 'general.learn_more' | t
	endif
-%}

{%- if menu.links.size > 0 -%}

{{ 'block-header-bottom.min.css' | asset_url | stylesheet_tag }}

{% style %}
	#shopify-section-{{ section.id }}.block-header-bottom {
		background-color: {{ section.settings.background_color | default: '#ffffff' }};
		color: {{ section.settings.text_color | default: '#2e130d' }};
	}
{% endstyle %}

<div class="block-header-bottom__wrapper" data-nav-id="{{ section.id }}">
	<nav class="block-header-bottom__nav" aria-label="{{ section.settings.menu | replace: '-', ' ' | capitalize }}">
		<div class="block-header-bottom__menu-wrapper is-align-wide">

			<ul class="block-header-bottom__menu">
				{%- for link in menu.links -%}
					<li class="block-header-bottom__item{% if link.links.size > 0 %} has-dropdown{% endif %}"{% if link.links.size > 0 %} data-menu-index="{{ forloop.index0 }}"{% endif %}>
						<a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>
							<span>{{ link.title }}</span>
						</a>
					</li>
				{%- endfor -%}
			</ul>

			{{- '<!-- single shared dropdown panel -->' -}}
			<div class="block-header-bottom__dropdown" id="nav-panel-{{ section.id }}">
				<div class="block-header-bottom__dropdown-inner is-align-wide">
					<section class="block-header-bottom__links">
						<ul class="block-header-bottom__panel-links"></ul>
					</section>
					<section class="block-header-bottom__assist" style="display:none"></section>
				</div>
			</div>

		</div>
	</nav>

	{{- '<!-- SEO: all child links, visually hidden but crawlable -->' -}}
	<div class="block-header-bottom__seo-links" aria-hidden="true">
		{%- for link in menu.links -%}
			{%- for child in link.links -%}
				<a href="{{ child.url }}">{{ child.title }}</a>
				{%- for subchild in child.links -%}
					<a href="{{ subchild.url }}">{{ subchild.title }}</a>
				{%- endfor -%}
			{%- endfor -%}
		{%- endfor -%}
	</div>
</div>

{{- '<!-- menu data for JS panel rendering -->' -}}
<script type="application/json" id="nav-data-{{ section.id }}">[
	{%- for link in menu.links -%}
	{%- liquid
		assign detected_collection = false
		assign detected_assist = false
		if link.url contains '/collections/'
			assign url_parts = link.url | split: '/'
			assign handle = url_parts.last
			assign detected_collection = collections[handle]
		endif
		if detected_collection
			assign detected_assist = detected_collection.metafields.custom['collection-assist-reference']
		endif
	-%}
	{
		"url": {{ link.url | json }},
		"title": {{ link.title | json }},
		"links": [
			{%- for child in link.links -%}
			{%- liquid
				assign link_collection = false
				assign child_image_url = nil
				assign child_image_alt = child.title
				if child.url contains '/collections/'
					assign url_parts = child.url | split: '/'
					assign handle = url_parts.last
					assign link_collection = collections[handle]
				endif
				if link_collection.image
					assign child_image_url = link_collection.image | image_url: width: 96
					assign child_image_alt = link_collection.image.alt | default: link_collection.title | default: child.title
				endif
			-%}
			{
				"url": {{ child.url | json }},
				"title": {{ child.title | json }},
				"imageUrl": {{ child_image_url | json }},
				"imageAlt": {{ child_image_alt | json }},
				"links": [
					{%- for subchild in child.links -%}
					{%- liquid
						assign sublink_collection = false
						assign subchild_image_url = nil
						assign subchild_image_alt = subchild.title
						if subchild.url contains '/collections/'
							assign url_parts = subchild.url | split: '/'
							assign handle = url_parts.last
							assign sublink_collection = collections[handle]
						endif
						if sublink_collection.image
							assign subchild_image_url = sublink_collection.image | image_url: width: 96
							assign subchild_image_alt = sublink_collection.image.alt | default: sublink_collection.title | default: subchild.title
						endif
					-%}
					{
						"url": {{ subchild.url | json }},
						"title": {{ subchild.title | json }},
						"imageUrl": {{ subchild_image_url | json }},
						"imageAlt": {{ subchild_image_alt | json }}
					}{% unless forloop.last %},{% endunless %}
					{%- endfor -%}
				]
			}{% unless forloop.last %},{% endunless %}
			{%- endfor -%}
		],
		"assist": {%- if detected_assist -%}
			{%- assign assist = detected_assist.value -%}
			{%- assign assist_image_url = nil -%}
			{%- if assist.image -%}{%- assign assist_image_url = assist.image | image_url: width: 520 -%}{%- endif -%}
			{
				"title": {{ assist.title | json }},
				"imageUrl": {{ assist_image_url | json }},
				"pageUrl": {{ assist.page.value.url | json }},
				"linkText": {{ assist_link_text | json }}
			}
		{%- else -%}null{%- endif -%}
	}{% unless forloop.last %},{% endunless %}
	{%- endfor -%}
]</script>

<script src="{{ 'block-header-bottom.min.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
	"name": "Header bottom",
	"tag": "section",
	"class": "block-header-bottom",
	"limit": 1,
	"enabled_on": {
		"groups": ["header"]
	},
	"settings": [
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "link_list",
			"id": "menu",
			"label": "Menu"
		},
		{
			"type": "text",
			"id": "assist_link_text",
			"label": "Assist link text",
			"info": "Leave empty to use locale default"
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Text"
		},
		{
			"type": "header",
			"content": "Howto"
		},
		{
			"type": "paragraph",
			"content": "Select a menu with nested links. Dropdowns show collection images when links point to collections. Assist content is pulled from collection metafields."
		}
	],
	"presets": [
		{
			"name": "Navigation",
			"category": "Header"
		}
	]
}
{% endschema %}
