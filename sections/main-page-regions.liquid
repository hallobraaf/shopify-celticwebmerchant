{%- comment -%}
  ============================================================================
  MAIN-PAGE-REGIONS
  ============================================================================

  Purpose:
  Full-page region/language switcher inspired by UPS's location selector.
  Features a sticky group tab-nav, large group headings with accent, a
  top recommendation panel based on the visitor's active locale, and a
  multi-column grid of regions within each group.

  Block Types:
  - "group"    block: renders a tab + section heading (e.g. "Europa")
  - "region"   block: renders a row in the grid (e.g. "Nederland")
  - "language" block: inline language link belonging to the preceding region

  Usage:
  Assign to templates/page.regions.json.
  Stack blocks: Group → Region → Language → Language → Region → …

  Dependencies:
  - html-theme-media-image snippet
  - theme-ux.css

  ============================================================================
{%- endcomment -%}

{%- liquid
  assign current_country  = localization.country.iso_code | downcase
  assign current_language = localization.language.iso_code | downcase
  assign current_market   = localization.market.handle | downcase

  assign show_recommendation = section.settings.show_recommendation
  assign recommendation_image = section.settings.recommendation_image

  assign columns_desktop = section.settings.columns_desktop | default: 4
  assign columns_tablet  = section.settings.columns_tablet  | default: 3
  assign columns_mobile  = section.settings.columns_mobile  | default: 2
-%}

{%- comment -%}
  Pass 1 — find the active group and capture its regions for the recommendation panel.
  We track which group we're in and reset when we find the first matching language.
{%- endcomment -%}
{%- liquid
  assign rec_group_title  = nil
  assign rec_found        = false
  assign rec_in_group     = false
  assign rec_in_market    = false
  assign rec_group_index  = nil

  for block in section.blocks
    case block.type
      when 'group'
        if rec_found == false
          assign rec_group_title = block.settings.title
        endif
        assign rec_in_group  = true
        assign rec_in_market = false
      when 'region'
        assign rec_in_market = true
      when 'language'
        if rec_in_group and rec_found == false
          assign ll = block.settings.language_code
          assign lm = block.settings.market_handle
          assign lc = block.settings.country_code
          if lm != blank
            assign url_prefix = '/' | append: ll | append: '-' | append: lm
            assign path_start = request.path | slice: 0, url_prefix.size
            if path_start == url_prefix
              assign rec_found = true
            endif
          elsif lc == current_country and ll == current_language
            assign rec_found = true
          endif
        endif
    endcase
  endfor
-%}

<div class="main-page-regions">

  {%- if section.blocks.size > 0 -%}

    {%- comment -%}
      Pass 2 — Recommendation cover panel or plain hero.
      When recommendation is enabled and a match is found: full-width cover with
      absolute background image and a white content card over it.
      When disabled: plain heading/subheading above the nav.
    {%- endcomment -%}
    {%- if show_recommendation and rec_found -%}
      <div class="main-page-regions__cover">

        {%- comment -%} Full-width background image {%- endcomment -%}
        <div class="main-page-regions__cover-bg" aria-hidden="true">
          {%- if recommendation_image != blank -%}
            {%- render 'html-theme-media-image',
              image: recommendation_image,
              alt: '',
              w1: 800,
              w2: 1200,
              w3: 1600,
              sizes: '100vw'
            -%}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'main-page-regions__cover-placeholder' }}
          {%- endif -%}
        </div>

        {%- comment -%} Width-constrained inner — aligns white card {%- endcomment -%}
        <div class="main-page-regions__cover-inner {{ section.settings.width }}">
          <div class="main-page-regions__cover-card">

            {%- if section.settings.heading != blank -%}
              <h1 class="main-page-regions__heading">{{ section.settings.heading }}</h1>
            {%- endif -%}
            {%- if section.settings.subheading != blank -%}
              <p class="main-page-regions__subheading">{{ section.settings.subheading }}</p>
            {%- endif -%}

            {%- if rec_group_title != blank -%}
              <p class="main-page-regions__recommendation-label">{{ rec_group_title }}</p>
            {%- endif -%}

            <div class="main-page-regions__recommendation-grid">
              {%- liquid
                assign r_in_group  = false
                assign r_in_market = false
                assign r_active_group_done = false
              -%}
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'group' -%}
                    {%- if r_in_market -%}</span></div>{%- assign r_in_market = false -%}{%- endif -%}
                    {%- if r_in_group and r_active_group_done == false -%}
                      {%- assign r_active_group_done = true -%}
                    {%- endif -%}
                    {%- if block.settings.title == rec_group_title and r_active_group_done == false -%}
                      {%- assign r_in_group = true -%}
                    {%- else -%}
                      {%- assign r_in_group = false -%}
                    {%- endif -%}

                  {%- when 'region' -%}
                    {%- if r_in_group -%}
                      {%- if r_in_market -%}</span></div>{%- endif -%}
                      {%- assign r_in_market = true -%}
                      <div class="main-page-regions__market">
                        {%- if block.settings.title != blank -%}
                          <span class="main-page-regions__market-name">{{ block.settings.title }}</span>
                        {%- endif -%}
                        <span class="main-page-regions__languages">
                    {%- endif -%}

                  {%- when 'language' -%}
                    {%- if r_in_group -%}
                      {%- liquid
                        assign lang_label    = block.settings.label
                        assign lang_country  = block.settings.country_code
                        assign lang_language = block.settings.language_code
                        assign lang_market   = block.settings.market_handle
                        assign is_active     = false
                        if lang_market != blank
                          assign url_prefix = '/' | append: lang_language | append: '-' | append: lang_market
                          assign path_start = request.path | slice: 0, url_prefix.size
                          if path_start == url_prefix
                            assign is_active = true
                          endif
                        elsif lang_country == current_country and lang_language == current_language
                          assign is_active = true
                        endif
                      -%}
                      {%- if lang_label != blank and lang_language != blank -%}
                        {%- if is_active -%}
                          <span class="main-page-regions__lang-btn is-active" aria-current="true">{{ lang_label }}</span>
                        {%- elsif lang_market != blank -%}
                          <a class="main-page-regions__lang-btn" href="/{{ lang_language }}-{{ lang_market }}">{{ lang_label }}</a>
                        {%- else -%}
                          {%- form 'localization', class: 'main-page-regions__form' -%}
                            <input type="hidden" name="country_code"  value="{{ lang_country }}">
                            <input type="hidden" name="language_code" value="{{ lang_language }}">
                            <button type="submit" class="main-page-regions__lang-btn">{{ lang_label }}</button>
                          {%- endform -%}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endif -%}
                {%- endcase -%}
              {%- endfor -%}
              {%- if r_in_market -%}</span></div>{%- endif -%}
            </div>
          </div>
        </div>
      </div>

    {%- else -%}

      {%- comment -%} Plain hero — no recommendation {%- endcomment -%}
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="main-page-regions__hero {{ section.settings.width }}">
          {%- if section.settings.heading != blank -%}
            <h1 class="main-page-regions__heading">{{ section.settings.heading }}</h1>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class="main-page-regions__subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- endif -%}

    {%- comment -%}
      Pass 3 — sticky tab nav (groups only)
    {%- endcomment -%}
    {%- assign has_groups = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'group' -%}{%- assign has_groups = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_groups -%}
      <nav class="main-page-regions__nav {{ section.settings.width }}" aria-label="{{ 'localization.region_nav' | t | default: 'Regions' }}">
        <div class="main-page-regions__nav-inner page-width">
          {%- for block in section.blocks -%}
            {%- if block.type == 'group' and block.settings.title != blank -%}
              <a class="main-page-regions__nav-link" href="#group-{{ block.id }}">
                {{ block.settings.title }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </nav>
    {%- endif -%}

    {%- comment -%}
      Pass 4 — full content render
    {%- endcomment -%}
    <div class="main-page-regions__body {{ section.settings.width }}">
      
      <!-- <p style="font-size:0.75rem;opacity:0.5">
        market: {{ localization.market.handle }} |
        lang: {{ localization.language.iso_code }} |
        country: {{ localization.country.iso_code }}
      </p> -->
      
      {%- liquid
        assign in_group  = false
        assign in_market = false
      -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'group' -%}
            {%- if in_market -%}</span></div>{%- assign in_market = false -%}{%- endif -%}
            {%- if in_group -%}</div></section>{%- assign in_group = false -%}{%- endif -%}
            {%- assign in_group = true -%}
            <section class="main-page-regions__group" id="group-{{ block.id }}" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <h2 class="main-page-regions__group-name">{{ block.settings.title }}</h2>
              {%- endif -%}
              <div class="main-page-regions__grid">

          {%- when 'region' -%}
            {%- if in_market -%}</span></div>{%- assign in_market = false -%}{%- endif -%}
            {%- assign in_market = true -%}
            <div class="main-page-regions__market" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <span class="main-page-regions__market-name">{{ block.settings.title }}</span>
              {%- endif -%}
              <span class="main-page-regions__languages">

          {%- when 'language' -%}
            {%- liquid
              assign lang_label    = block.settings.label
              assign lang_country  = block.settings.country_code
              assign lang_language = block.settings.language_code
              assign lang_market   = block.settings.market_handle
              assign is_active     = false
              if lang_market != blank
                assign url_prefix = '/' | append: lang_language | append: '-' | append: lang_market
                assign path_start = request.path | slice: 0, url_prefix.size
                if path_start == url_prefix
                  assign is_active = true
                endif
              elsif lang_country == current_country and lang_language == current_language
                assign is_active = true
              endif
            -%}
            {%- if lang_label != blank and lang_language != blank -%}
              {%- if is_active -%}
                <span class="main-page-regions__lang-btn is-active" aria-current="true" {{ block.shopify_attributes }}>{{ lang_label }}</span>
              {%- elsif lang_market != blank -%}
                <a class="main-page-regions__lang-btn" href="/{{ lang_language }}-{{ lang_market }}" {{ block.shopify_attributes }}>{{ lang_label }}</a>
              {%- else -%}
                {%- form 'localization', class: 'main-page-regions__form' -%}
                  <input type="hidden" name="country_code"  value="{{ lang_country }}">
                  <input type="hidden" name="language_code" value="{{ lang_language }}">
                  <button type="submit" class="main-page-regions__lang-btn" {{ block.shopify_attributes }}>{{ lang_label }}</button>
                {%- endform -%}
              {%- endif -%}
            {%- endif -%}

        {%- endcase -%}
      {%- endfor -%}

      {%- if in_market -%}</span></div>{%- endif -%}
      {%- if in_group -%}</div></section>{%- endif -%}
    </div>

  {%- endif -%}

</div>

<style>
  /* ── Page wrapper ────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions {
    padding-block-end: {{ section.settings.padding_block }}em;
    max-width:100vw!important;
  }

  /* ── Plain hero (no recommendation) ────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__hero {
    padding-block: 3rem 2rem;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .main-page-regions__heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  #shopify-section-{{ section.id }} .main-page-regions__subheading {
    margin: 0;
    font-size: 1rem;
    opacity: 0.6;
  }

  /* ── Cover panel ─────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__cover {
    position: relative;
    overflow: hidden;
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
  }

  #shopify-section-{{ section.id }} .main-page-regions__cover-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .main-page-regions__cover-bg .theme-media__picture,
  #shopify-section-{{ section.id }} .main-page-regions__cover-bg .theme-media__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .main-page-regions__cover-placeholder {
    width: 100%;
    height: 100%;
    opacity: 0.15;
  }

  #shopify-section-{{ section.id }} .main-page-regions__cover-inner {
    position: relative;
    z-index: 1;
    margin-inline: auto;
    padding-block: 3rem;
    display: flex;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .main-page-regions__cover-card {
    background: #fff;
    padding: 2rem;
    max-width: 560px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
  }

  #shopify-section-{{ section.id }} .main-page-regions__cover-card .main-page-regions__heading {
    margin-block-end: 1.5rem;
  }

  #shopify-section-{{ section.id }} .main-page-regions__cover-card .main-page-regions__subheading {
    margin-block-end: 1.5rem;
  }

  /* ── Recommendation regions grid ────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__recommendation-label {
    margin: 0 0 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.4;
  }

  #shopify-section-{{ section.id }} .main-page-regions__recommendation-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 0.4rem 1.25rem;
  }

  /* ── Sticky tab nav ──────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--theme-color-white, #fff);
    border-block-end: 1px solid rgba(0, 0, 0, 0.1);
  }

  #shopify-section-{{ section.id }} .main-page-regions__nav-inner {
    display: flex;
    flex-wrap: wrap;
    overflow-x: auto;
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .main-page-regions__nav-inner::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .main-page-regions__nav-link {
    display: inline-block;
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.6;
    border-block-end: 2px solid transparent;
    transition: border-color 150ms ease, opacity 150ms ease;
  }

  #shopify-section-{{ section.id }} .main-page-regions__nav-link:hover,
  #shopify-section-{{ section.id }} .main-page-regions__nav-link.is-active {
    opacity: 1;
    border-block-end-color: currentColor;
  }

  /* ── Body ────────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__body {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-block-start: 3rem;
  }

  /* ── Group section ───────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__group {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    scroll-margin-top: 4rem;
  }

  #shopify-section-{{ section.id }} .main-page-regions__group-name {
    margin: 0;
    padding-block-end: 0.75rem;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    border-block-end: 3px solid var(--theme-color-blue, #0f1f38);
    display: inline-block;
  }

  /* ── Grid ────────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__grid {
    display: grid;
    grid-template-columns: repeat({{ columns_desktop }}, 1fr);
    gap: 0.5rem 2rem;
  }

  /* ── Region row ──────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__market {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .main-page-regions__market-name {
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .main-page-regions__market-name + .main-page-regions__languages::before {
    content: '|';
    margin-inline: 0.25em;
    opacity: 0.3;
  }

  /* ── Languages ───────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .main-page-regions__languages {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .main-page-regions__form {
    display: contents;
  }

  #shopify-section-{{ section.id }} .main-page-regions__languages > * + *::before {
    content: '|';
    margin-inline: 0.25em;
    opacity: 0.3;
    display: inline-block;
  }

  #shopify-section-{{ section.id }} .main-page-regions__lang-btn {
    display: inline;
    padding: 0;
    background: transparent;
    border: none;
    font-family: inherit;
    font-size: 0.9rem;
    color: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 150ms ease;
  }

  #shopify-section-{{ section.id }} button.main-page-regions__lang-btn:hover {
    opacity: 0.6;
  }

  #shopify-section-{{ section.id }} .main-page-regions__lang-btn.is-active {
    font-weight: 600;
    text-decoration: none;
    cursor: default;
    opacity: 1;
  }

  /* ── Responsive: tablet ──────────────────────────────────────────── */
  @media (max-width: 960px) {
    #shopify-section-{{ section.id }} .main-page-regions__grid {
      grid-template-columns: repeat({{ columns_tablet }}, 1fr);
    }

    #shopify-section-{{ section.id }} .main-page-regions__recommendation-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Responsive: mobile ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .main-page-regions__grid {
      grid-template-columns: repeat({{ columns_mobile }}, 1fr);
    }

    #shopify-section-{{ section.id }} .main-page-regions__recommendation-grid {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .main-page-regions__cover-card {
      max-width: 100%;
    }
  }
</style>

<script>
  (function() {
    var nav = document.querySelector('#shopify-section-{{ section.id }} .main-page-regions__nav');
    if (!nav) return;

    var links    = Array.from(nav.querySelectorAll('.main-page-regions__nav-link'));
    var sections = links.map(function(l) {
      return document.querySelector(l.getAttribute('href'));
    }).filter(Boolean);

    function setActive() {
      var scrollY  = window.scrollY + nav.offsetHeight + 40;
      var current  = sections[0];
      sections.forEach(function(s) {
        if (s.offsetTop <= scrollY) current = s;
      });
      links.forEach(function(l) {
        l.classList.toggle('is-active', l.getAttribute('href') === '#' + current.id);
      });
    }

    window.addEventListener('scroll', setActive, { passive: true });
    setActive();
  })();
</script>

{% schema %}
{
  "name": "Region switcher",
  "tag": "section",
  "class": "main-page-regions",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "placeholder": "Choose your region"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "placeholder": "Select your country and language"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "recommendation_image",
      "label": "Recommendation image",
      "info": "Shown next to the top recommendation panel"
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "checkbox",
      "id": "show_recommendation",
      "label": "Show top recommendation",
      "info": "Highlights the group matching the visitor's current locale",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "is-align-narrow", "label": "Narrow" },
        { "value": "is-align-small",  "label": "Small" },
        { "value": "is-align",        "label": "Regular" },
        { "value": "is-align-wide",   "label": "Wide" },
        { "value": "is-align-full",   "label": "Full" }
      ],
      "default": "is-align"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_block",
      "label": "Vertical padding",
      "min": 0,
      "max": 8,
      "step": 0.5,
      "default": 4,
      "unit": "em"
    },
    {
      "type": "header",
      "content": "Howto"
    },
    {
      "type": "paragraph",
      "content": "Stack blocks: Group → Region → Language → Language → Region → … Group creates a tab in the nav and a heading. The group matching the visitor's locale is shown as top recommendation."
    }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Group",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "placeholder": "Europa"
        }
      ]
    },
    {
      "type": "region",
      "name": "Region",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "placeholder": "Nederland"
        }
      ]
    },
    {
      "type": "language",
      "name": "Language",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "placeholder": "Nederlands"
        },
        {
          "type": "text",
          "id": "language_code",
