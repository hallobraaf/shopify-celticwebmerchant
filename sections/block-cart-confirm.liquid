{%- comment -%}
  ============================================================================
  BLOCK-CART-CONFIRM
  ============================================================================

  Purpose:
  Confirmation drawer that auto-opens after a product is added to the cart.
  Shows the just-added product (confirmation block) and recommended products
  from that product's metafield (recommended block). Single CTA in footer:
  "View cart".

  Usage:
  Add to footer-group.json. Auto-opens on cart:add via window.CartEvents.
  Drawer-id: cart-confirm-drawer (distinct from cart-drawer used by cart-preview).

  Layout:
  - Body container is empty on initial render (filled via section_id fetch on cart:add).
  - Footer: single "View cart" button (no subtotal, no payments).

  Render flow:
  - On every page render, the section emits the drawer shell with empty body.
  - On cart:add, JS fetches /products/{handle}?section_id={this section}&variant={id},
    parses the response, and swaps in the body content.
  - The fetched response runs the section's blocks loop with product context,
    rendering confirmation + recommended snippets.

  Dependencies:
  - theme-drawer.js
  - theme-cart.js (for window.CartEvents)
  - html-cart-confirm-product snippet
  - html-cart-confirm-recommended snippet
  - html-theme-card snippet (via recommended snippet)
  - html-theme-icons snippet

  ============================================================================
{%- endcomment -%}

<div
  class="block-cart-confirm"
  id="cart-confirm"
  data-drawer="cart-confirm-drawer"
  data-drawer-position="right"
  data-cart-confirm-section="{{ section.id }}"
  data-cart-context="confirm"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'marketing.cart_confirm.heading' | t }}"
  hidden
>
  <div class="block-cart-confirm__overlay" data-drawer-overlay></div>

  <div class="block-cart-confirm__content theme-drawer__content">
    {%- comment -%} Header {%- endcomment -%}
    <div class="block-cart-confirm__header theme-drawer__header">
      <h2 class="block-cart-confirm__title theme-drawer__title">
        {{ 'marketing.cart_confirm.heading' | t }}
      </h2>
      <button
        class="block-cart-confirm__close theme-drawer__close"
        type="button"
        aria-label="{{ 'accessibility.close' | t }}"
        data-drawer-close
      >
        {%- render 'html-theme-icons', icon: 'close', size: 24 -%}
      </button>
    </div>

    {%- comment -%}
      Body — populated server-side when product context is available
      (e.g., during section_id fetch on /products/{handle}). Otherwise empty.
    {%- endcomment -%}
    <div
      class="block-cart-confirm__body theme-drawer__body"
      data-confirm-body
      data-section-id="{{ section.id }}"
    >
      {%- if product != blank -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'confirmation' -%}
              <div class="block-cart-confirm__block block-cart-confirm__block--confirmation" {{ block.shopify_attributes }}>
                {%- render 'html-cart-confirm-product',
                  product: product,
                  variant: product.selected_or_first_available_variant,
                  quantity: 1,
                  show_variant_title: block.settings.show_variant_title,
                  show_quantity: block.settings.show_quantity,
                  show_price: block.settings.show_price,
                  image_size: block.settings.image_size
                -%}
              </div>

            {%- when 'recommended' -%}
              <div class="block-cart-confirm__block block-cart-confirm__block--recommended" {{ block.shopify_attributes }}>
                {%- render 'html-cart-confirm-recommended',
                  product: product,
                  heading: block.settings.heading,
                  max_products: block.settings.max_products,
                  hide_out_of_stock: block.settings.hide_out_of_stock,
                  cart_rec_mode: block.settings.rec_mode,
                  card_layout: block.settings.card_layout,
                  card_sizing: block.settings.card_sizing,
                  image_ratio: block.settings.image_ratio,
                  show_secondary_image: block.settings.show_secondary_image,
                  show_rating: block.settings.show_rating,
                  show_vendor: block.settings.show_vendor,
                  show_badges: block.settings.show_badges,
                  show_stock: block.settings.show_stock,
                  show_delivery: block.settings.show_delivery,
                  quick_add: block.settings.quick_add
                -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Footer — single View cart CTA {%- endcomment -%}
    <div class="block-cart-confirm__footer theme-drawer__footer">
      <a href="{{ routes.cart_url }}" class="block-cart-confirm__view-cart">
        {{ 'cart.view_cart' | t | default: 'View cart' }}
      </a>
    </div>
  </div>
</div>

<style>
  .block-cart-confirm__content {
    width: 100%;
    max-width: 420px;
  }

  .block-cart-confirm__body {
    flex: 1 1 auto;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 1rem;
  }

  .block-cart-confirm__footer {
    flex-direction: column;
  }

  .block-cart-confirm__block {
    margin-bottom: 1.5rem;
  }

  .block-cart-confirm__block:last-child {
    margin-bottom: 0;
  }

  .block-cart-confirm__view-cart {
    display: block;
    margin-top: 0;
    padding: 0.75rem 1.5rem;
    background: var(--theme-color-green, #111);
    border: 0px solid currentColor;
    color: var(--theme-color-white, #fff);
    text-align: center;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 200ms ease, color 200ms ease;
  }

  .block-cart-confirm__view-cart:hover {
    background: var(--theme-color-green, #111);
    color: var(--theme-color-white, #fff);
    opacity: 0.9;
  }

  /* Confirmation product card */
  .cart-confirm-product {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    
    background: var(--theme-color-grey, #f6f6f6);
    border-radius: 4px;
  }

  .cart-confirm-product__media {
    flex-shrink: 0;
    display: block;
    text-decoration: none;
  }

  .cart-confirm-product__image {
    display: block;
    width: 96px;
    height: auto;
    object-fit: cover;
    border-radius: 2px;
  }

  .cart-confirm-product--small .cart-confirm-product__image {
    width: 64px;
  }

  .cart-confirm-product__details {
    flex: 1 1 auto;
    padding: 0.75rem;
    min-width: 0;
  }

  /* Just-added card text is sized one step up from the recommended items
     below, so the primary "you added X" message is the visual anchor of
     the drawer body. */
  .cart-confirm-product__title {
    margin: 0 0 0.35rem;
    font-size: 1.4rem;
    line-height: 1.3;
    font-weight: 500;
  }

  .cart-confirm-product__title a {
    color: inherit;
    text-decoration: none;
  }

  .cart-confirm-product__title a:hover {
    text-decoration: underline;
  }

  .cart-confirm-product__variant {
    margin: 0 0 0.5rem;
    font-size: 0.9375rem;
    opacity: 0.7;
  }

  .cart-confirm-product__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 1rem;
  }

  .cart-confirm-product__quantity {
    opacity: 0.7;
  }

  .cart-confirm-product__price {
    font-weight: 500;
  }

  .cart-confirm-product__price-compare {
    opacity: 0.5;
    margin-right: 0.25rem;
  }

  .cart-confirm-product__price-sale {
    color: var(--theme-color-red, #c00);
  }

  /* Recommended list */
  .cart-confirm-recommended__heading {
    margin: 0 0 0.75rem;
    font-size: 1.2rem;
    font-weight: 600;
  }

  .cart-confirm-recommended__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cart-confirm-recommended__item {
    margin: 0;
  }

  /* Compact horizontal cards, scoped to this drawer only.
     Theme-ux.scss base sets .card--horizontal to grid-template-columns: 35% 1fr.
     In a narrow drawer (~420px) that's still ~140px image which dominates the row.
     Override the grid track with a fixed 64px image column so the text gets
     the rest, the layout stays predictable, and other horizontal cards
     elsewhere on the site keep their normal proportions. */
  .cart-confirm-recommended .card--horizontal {
    grid-template-columns: 64px 1fr;
  }

  @media (max-width: 40em) {
    .block-cart-confirm__content {
      max-width: 100%;
    }
  }
</style>

<script>
  (function() {
    const sectionEl = document.querySelector('[data-cart-confirm-section="{{ section.id }}"]');
    if (!sectionEl) return;

    const bodyEl = sectionEl.querySelector('[data-confirm-body]');
    const sectionId = '{{ section.id }}';

    /**
     * Fetch the section re-rendered in the context of a specific product +
     * variant, swap in the body, then patch the qty (URL params don't carry
     * quantity to Liquid context).
     *
     * Returns the section HTML response status (true if injected, false if
     * fetch/parse failed — caller may decide whether to still open drawer).
     */
    async function loadAndInject(handle, variantId, qty) {
      if (!handle || !bodyEl) return false;
      const params = new URLSearchParams({ section_id: sectionId });
      if (variantId) params.set('variant', variantId);

      try {
        const res = await fetch('/products/' + encodeURIComponent(handle) + '?' + params.toString(), {
          headers: { 'Accept': 'text/html' }
        });
        if (!res.ok) return false;
        const html = await res.text();
        const parsed = new DOMParser().parseFromString(html, 'text/html');
        const newBody = parsed.querySelector('[data-confirm-body][data-section-id="' + sectionId + '"]');
        if (!newBody) return false;
        bodyEl.innerHTML = newBody.innerHTML;

        // Patch quantity (Liquid context can't see qty from URL alone)
        if (qty && qty > 0) {
          const qtyEl = bodyEl.querySelector('[data-cart-confirm-quantity]');
          if (qtyEl) qtyEl.textContent = qtyEl.textContent.replace(/\d+\s*$/, String(qty));
        }
        return true;
      } catch (err) {
        console.error('[cart-confirm] section fetch failed:', err);
        return false;
      }
    }

    /**
     * Public API. Always available regardless of settings.cart_type — so
     * other code (interceptor, manual triggers, app extensions) can drive
     * the drawer programmatically.
     *
     *   open()                                  — open with current body
     *   close()                                 — close drawer
     *   openWithProduct(handle, variantId, qty) — fetch fresh body for a
     *       specific product, then open. If drawer is already open
     *       (in-drawer quick-add), the call is a no-op so the focus
     *       stays on the original "just added" product.
     */
    window.CartConfirm = {
      open: function() {
        if (window.themeDrawer) window.themeDrawer.open('cart-confirm-drawer');
      },
      close: function() {
        if (window.themeDrawer) window.themeDrawer.close('cart-confirm-drawer');
      },
      openWithProduct: async function(handle, variantId, qty) {
        // Suppress recursive reopen on in-drawer quick-adds. The interceptor's
        // submit-button vinkje is sufficient feedback; cart-icon counter
        // updates separately.
        if (window.themeDrawer && window.themeDrawer.isOpen('cart-confirm-drawer')) {
          return;
        }
        await loadAndInject(handle, variantId, qty);
        if (window.themeDrawer) window.themeDrawer.open('cart-confirm-drawer');
      }
    };
  })();
</script>

{% schema %}
{
  "name": "Cart confirm",
  "tag": "section",
  "class": "section-cart-confirm",
  "limit": 1,
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Howto"
    },
    {
      "type": "paragraph",
      "content": "Auto-opens after add-to-cart. Shows the just-added product and its recommended products (metafield: custom.recommended-products). Add Confirmation and Recommended blocks below. Single CTA in footer goes to /cart."
    }
  ],
  "blocks": [
    {
      "type": "confirmation",
      "name": "Confirmation",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Display"
        },
        {
          "type": "checkbox",
          "id": "show_variant_title",
          "label": "Show variant title",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_quantity",
          "label": "Show quantity",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_price",
          "label": "Show price",
          "default": true
        },
        {
          "type": "select",
          "id": "image_size",
          "label": "Image size",
          "options": [
            { "value": "small",  "label": "Small (64px)" },
            { "value": "medium", "label": "Medium (96px)" }
          ],
          "default": "medium"
        }
      ]
    },
    {
      "type": "recommended",
      "name": "Recommended",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "info": "Leave empty to use locale default (product.recommended_heading)"
        },
        {
          "type": "range",
          "id": "max_products",
          "label": "Maximum products",
          "min": 1,
          "max": 8,
          "step": 1,
          "default": 4
        },
        {
          "type": "checkbox",
          "id": "hide_out_of_stock",
          "label": "Hide out of stock products",
          "default": false
        },
        {
          "type": "select",
          "id": "rec_mode",
          "label": "Recommendations source",
          "info": "Default = custom.recommended-products only (general curation). Cart = custom.recommended-products-cart only (cart-flow curation). Combined = cart metafield first (priority), default as fill. Combined recommended for highest conversion.",
          "options": [
            { "value": "default",  "label": "Default" },
            { "value": "cart",     "label": "Cart" },
            { "value": "combined", "label": "Combined" }
          ],
          "default": "combined"
        },
        {
          "type": "header",
          "content": "Card"
        },
        {
          "type": "select",
          "id": "card_layout",
          "label": "Card layout",
          "options": [
            { "value": "horizontal", "label": "Horizontal" },
            { "value": "vertical",   "label": "Vertical" }
          ],
          "default": "horizontal"
        },
        {
          "type": "select",
          "id": "card_sizing",
          "label": "Card sizing",
          "options": [
            { "value": "smaller", "label": "Smaller" },
            { "value": "regular", "label": "Regular" }
          ],
          "default": "smaller"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Image ratio",
          "options": [
            { "value": "square",    "label": "Square (1:1)" },
            { "value": "portrait",  "label": "Portrait (2:3)" },
            { "value": "landscape", "label": "Landscape (3:2)" },
            { "value": "adapt",     "label": "Adapt (original)" }
          ],
          "default": "square"
        },
        {
          "type": "checkbox",
          "id": "show_secondary_image",
          "label": "Show secondary image on hover",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "Show rating",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_vendor",
          "label": "Show vendor",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_badges",
          "label": "Show badges",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_stock",
          "label": "Show stock status",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_delivery",
          "label": "Show delivery date",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "quick_add",
          "label": "Show quick add button",
          "default": true
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Cart confirm",
      "category": "Cart",
      "blocks": [
        { "type": "confirmation" },
        { "type": "recommended" }
      ]
    }
  ]
}
{% endschema %}
