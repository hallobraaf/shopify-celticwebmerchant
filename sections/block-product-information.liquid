{%- comment -%}
============================================================================
BLOCK-PRODUCT-INFORMATION
============================================================================
Product description and additional information from metafields.

FEATURES:
- Collapsible product description with read more/less
- Product details from metafield
- Size chart in modal (always)
- Information references: inline details (≤128 chars) or modal (>128 chars)
- Responsive two-column layout

DEPENDENCIES:
- html-theme-icons snippet
- theme-modal.js
- Product metafields:
  - custom.product_details
  - custom.product-sizechart
  - custom.product-information-references
============================================================================
{%- endcomment -%}

{{ 'block-product-information.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'block-product-information.min.js' | asset_url }}" defer></script>

{% style %}
	#shopify-section-{{ section.id }}.block-product-information {
		{%- if section.settings.background_color != blank %}
		background-color: {{ section.settings.background_color }};
		{%- endif %}
		{%- if section.settings.text_color != blank %}
		color: {{ section.settings.text_color }};
		{%- endif %}
		padding-block: {{ section.settings.padding_block }}em;
	}
{% endstyle %}

{%- liquid
	assign refs = product.metafields.custom['product-information-references']
	assign has_refs = false
	if refs and refs.value
		assign has_refs = true
	endif
	assign has_sizechart = false
	if product.metafields.custom['product-sizechart'] != blank
		assign has_sizechart = true
	endif
	assign content_threshold = 128

	assign description_heading = section.settings.description_heading
	if description_heading == blank
		assign description_heading = 'product.description_heading' | t
	endif
	assign details_heading = section.settings.details_heading
	if details_heading == blank
		assign details_heading = 'product.details_heading' | t
	endif
	assign sizechart_heading = section.settings.sizechart_heading
	if sizechart_heading == blank
		assign sizechart_heading = 'product.sizechart_heading' | t
	endif
	assign read_more_text = section.settings.read_more_text
	if read_more_text == blank
		assign read_more_text = 'general.read_more' | t
	endif
	assign read_less_text = section.settings.read_less_text
	if read_less_text == blank
		assign read_less_text = 'general.read_less' | t
	endif
-%}

<div class="block-product-information__content {{ section.settings.width }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"{% if section.settings.anchor != blank %} id="{{ section.settings.anchor }}"{% endif %}>
	<article class="block-product-information__article">
		<div class="block-product-information__main">
			{%- if product.description != blank -%}
				<section
					class="block-product-information__description{% if has_refs %} has-product-references{% endif %}"
					data-readmore="collapsed"
					data-readmore-paragraphs="1"
					aria-live="polite"
				>
					<h2 class="block-product-information__heading">{{ description_heading }}</h2>
					{{ product.description
						| replace: '<br><br>', '</p><p>'
						| replace: '<p hidden></p>', ''
						| replace: '<p hidden="hidden"></p>', ''
						| replace: '<p aria-hidden="true"></p>', ''
						| replace: '<p>&nbsp;</p>', ''
						| replace: '<p> &nbsp; </p>', ''
						| replace: '<p> </p>', ''
						| replace: '<p></p>', ''
					}}
					<button class="block-product-information__toggle" type="button" aria-expanded="false">
						<span data-label-collapsed>{{ read_more_text }}</span>
						<span data-label-expanded hidden>{{ read_less_text }}</span>
						{%- render 'html-theme-icons', icon: 'chevron-down', size: 20 -%}
					</button>
				</section>
			{%- endif -%}

			{%- if product.metafields.custom.product_details != blank -%}
				<section class="block-product-information__details">
					<details open>
						<summary>
							<span class="block-product-information__summary-icon">
								{%- render 'html-theme-icons', icon: 'details', size: 24 -%}
							</span>
							<span class="block-product-information__summary-label">{{ details_heading }}</span>
							<span class="block-product-information__summary-caret">
								{%- render 'html-theme-icons', icon: 'chevron-down', size: 20 -%}
							</span>
						</summary>
						<div class="block-product-information__details-list">
							{%- assign details_raw = product.metafields.custom.product_details.value | default: product.metafields.custom.product_details -%}
							{%- comment -%} Try splitting on <br> first, then <br/>, then <br /> {%- endcomment -%}
							{%- assign details_lines = details_raw | split: '<br>' -%}
							{%- if details_lines.size == 1 -%}
								{%- assign details_lines = details_raw | split: '<br/>' -%}
							{%- endif -%}
							{%- if details_lines.size == 1 -%}
								{%- assign details_lines = details_raw | split: '<br />' -%}
							{%- endif -%}
							{%- comment -%} If still no splits, output as single block without title styling {%- endcomment -%}
							{%- if details_lines.size == 1 -%}
								<div class="block-product-information__details-item">{{ details_raw }}</div>
							{%- else -%}
								{%- for line in details_lines -%}
									{%- assign line_stripped = line | strip_html | strip -%}
									{%- if line_stripped != blank -%}
										{%- if forloop.first -%}
											<div class="block-product-information__details-title">{{ line_stripped }}</div>
										{%- else -%}
											{%- assign line_parts = line_stripped | split: ': ' -%}
											{%- if line_parts.size > 1 -%}
												<div class="block-product-information__details-item">
													<strong>{{ line_parts.first }}:</strong> {{ line_parts | slice: 1, line_parts.size | join: ': ' }}
												</div>
											{%- else -%}
												<div class="block-product-information__details-item">{{ line_stripped }}</div>
											{%- endif -%}
										{%- endif -%}
									{%- endif -%}
								{%- endfor -%}
							{%- endif -%}
						</div>
					</details>
				</section>
			{%- endif -%}
		</div>

		{%- if has_refs or has_sizechart -%}
			<aside class="block-product-information__aside">
				<div class="block-product-information__references">

					{%- comment -%} Sizechart - always modal {%- endcomment -%}
					{%- if has_sizechart -%}
						<div class="block-product-information__item">
							<button
								type="button"
								class="block-product-information__trigger"
								data-modal-trigger="sizechart-modal-{{ section.id }}"
							>
								<span class="block-product-information__trigger-icon">
									{%- render 'html-theme-icons', icon: 'sizechart', size: 24 -%}
								</span>
								<span class="block-product-information__trigger-label">{{ sizechart_heading }}</span>
								<span class="block-product-information__trigger-arrow">
									{%- render 'html-theme-icons', icon: 'arrow-up-right', size: 18 -%}
								</span>
							</button>
						</div>
					{%- endif -%}

					{%- comment -%} Information references {%- endcomment -%}
					{%- if has_refs -%}
						{%- assign ref_items = refs.value -%}

						{%- comment -%} First pass: Inline details (short content) {%- endcomment -%}
						{%- assign ref_index = 0 -%}
						{%- for ref_item in ref_items -%}
							{%- liquid
								assign ref_type = ''
								if ref_item.type
									assign ref_info = ref_item.type.value
									assign ref_type = ref_info.system.handle
								endif

								assign ref_content = ref_item.content | metafield_tag
								assign ref_content_stripped = ref_content | strip_html | strip
								assign ref_content_size = ref_content_stripped | size
								assign use_modal = false
								if ref_content_size > content_threshold
									assign use_modal = true
								endif
							-%}

							{%- unless use_modal -%}
								{%- capture ref_icon -%}
									{%- case ref_type -%}
										{%- when 'verpakkingsinformatie' -%}
											{%- render 'html-theme-icons', icon: 'package', size: 24 -%}
										{%- when 'leeftijdsverificatie' -%}
											{%- render 'html-theme-icons', icon: 'shield-check', size: 24 -%}
										{%- when 'productie' -%}
											{%- render 'html-theme-icons', icon: 'factory', size: 24 -%}
										{%- when 'onderhoud' -%}
											{%- render 'html-theme-icons', icon: 'wrench', size: 24 -%}
										{%- when 'afwerking' -%}
											{%- render 'html-theme-icons', icon: 'sparkles', size: 24 -%}
										{%- when 'kwaliteitsclassificatie' -%}
											{%- render 'html-theme-icons', icon: 'badge', size: 24 -%}
										{%- when 'materiaal' -%}
											{%- render 'html-theme-icons', icon: 'layers', size: 24 -%}
										{%- when 'garantie' -%}
											{%- render 'html-theme-icons', icon: 'shield', size: 24 -%}
										{%- when 'opmeten' -%}
											{%- render 'html-theme-icons', icon: 'ruler', size: 24 -%}
										{%- when 'verzending' -%}
											{%- render 'html-theme-icons', icon: 'truck', size: 24 -%}
										{%- when 'bevestiging' -%}
											{%- render 'html-theme-icons', icon: 'bolt', size: 24 -%}
										{%- else -%}
											{%- render 'html-theme-icons', icon: 'info', size: 24 -%}
									{%- endcase -%}
								{%- endcapture -%}

								<details class="block-product-information__item block-product-information__item--{{ ref_type }}">
									<summary>
										<span class="block-product-information__summary-icon">{{ ref_icon }}</span>
										<span class="block-product-information__summary-label">{{ ref_item.title }}</span>
										<span class="block-product-information__summary-caret">
											{%- render 'html-theme-icons', icon: 'chevron-down', size: 20 -%}
										</span>
									</summary>
									<div class="block-product-information__item-content">
										{{ ref_content }}
									</div>
								</details>
							{%- endunless -%}

							{%- assign ref_index = ref_index | plus: 1 -%}
						{%- endfor -%}

						{%- comment -%} Second pass: Modal triggers (long content) {%- endcomment -%}
						{%- assign ref_index = 0 -%}
						{%- for ref_item in ref_items -%}
							{%- liquid
								assign ref_type = ''
								if ref_item.type
									assign ref_info = ref_item.type.value
									assign ref_type = ref_info.system.handle
								endif

								assign ref_content = ref_item.content | metafield_tag
								assign ref_content_stripped = ref_content | strip_html | strip
								assign ref_content_size = ref_content_stripped | size
								assign use_modal = false
								if ref_content_size > content_threshold
									assign use_modal = true
								endif
								assign modal_id = 'ref-modal-' | append: section.id | append: '-' | append: ref_index
							-%}

							{%- if use_modal -%}
								{%- capture ref_icon -%}
									{%- case ref_type -%}
										{%- when 'verpakkingsinformatie' -%}
											{%- render 'html-theme-icons', icon: 'package', size: 24 -%}
										{%- when 'leeftijdsverificatie' -%}
											{%- render 'html-theme-icons', icon: 'shield-check', size: 24 -%}
										{%- when 'productie' -%}
											{%- render 'html-theme-icons', icon: 'factory', size: 24 -%}
										{%- when 'onderhoud' -%}
											{%- render 'html-theme-icons', icon: 'wrench', size: 24 -%}
										{%- when 'afwerking' -%}
											{%- render 'html-theme-icons', icon: 'sparkles', size: 24 -%}
										{%- when 'kwaliteitsclassificatie' -%}
											{%- render 'html-theme-icons', icon: 'badge', size: 24 -%}
										{%- when 'materiaal' -%}
											{%- render 'html-theme-icons', icon: 'layers', size: 24 -%}
										{%- when 'garantie' -%}
											{%- render 'html-theme-icons', icon: 'shield', size: 24 -%}
										{%- when 'opmeten' -%}
											{%- render 'html-theme-icons', icon: 'ruler', size: 24 -%}
										{%- when 'verzending' -%}
											{%- render 'html-theme-icons', icon: 'truck', size: 24 -%}
										{%- when 'bevestiging' -%}
											{%- render 'html-theme-icons', icon: 'bolt', size: 24 -%}
										{%- else -%}
											{%- render 'html-theme-icons', icon: 'info', size: 24 -%}
									{%- endcase -%}
								{%- endcapture -%}

								<div class="block-product-information__item block-product-information__item--{{ ref_type }}">
									<button
										type="button"
										class="block-product-information__trigger"
										data-modal-trigger="{{ modal_id }}"
									>
										<span class="block-product-information__trigger-icon">{{ ref_icon }}</span>
										<span class="block-product-information__trigger-label">{{ ref_item.title }}</span>
										<span class="block-product-information__trigger-arrow">
											{%- render 'html-theme-icons', icon: 'arrow-up-right', size: 18 -%}
										</span>
									</button>
								</div>
							{%- endif -%}

							{%- assign ref_index = ref_index | plus: 1 -%}
						{%- endfor -%}
					{%- endif -%}
				</div>
			</aside>
		{%- endif -%}
	</article>
</div>

{%- comment -%} ============================================
   MODALS
   ============================================ {%- endcomment -%}

{%- comment -%} Sizechart Modal {%- endcomment -%}
{%- if has_sizechart -%}
	<div
		class="block-product-information__modal"
		data-modal="sizechart-modal-{{ section.id }}"
		role="dialog"
		aria-modal="true"
		aria-label="{{ sizechart_heading }}"
		hidden
	>
		<div class="block-product-information__modal-overlay" data-modal-overlay></div>
		<div class="block-product-information__modal-content theme-modal__content">
			<header class="block-product-information__modal-header theme-modal__header">
				<h3 class="block-product-information__modal-title theme-modal__title">
					{%- render 'html-theme-icons', icon: 'sizechart', size: 24 -%}
					{{ sizechart_heading }}
				</h3>
				<button type="button" class="block-product-information__modal-close theme-modal__close" data-modal-close aria-label="{{ 'accessibility.close' | t }}">
					{%- render 'html-theme-icons', icon: 'close', size: 24 -%}
				</button>
			</header>
			<div class="block-product-information__modal-body theme-modal__body">
				{{ product.metafields.custom['product-sizechart'].value | replace: '&lt;', '<' | replace: '&gt;', '>' }}
			</div>
		</div>
	</div>
{%- endif -%}

{%- comment -%} Reference Modals (only for long content) {%- endcomment -%}
{%- if has_refs -%}
	{%- assign ref_items = refs.value -%}
	{%- assign ref_index = 0 -%}
	{%- for ref_item in ref_items -%}
		{%- liquid
			assign ref_type = ''
			if ref_item.type
				assign ref_info = ref_item.type.value
				assign ref_type = ref_info.system.handle
			endif

			assign ref_content = ref_item.content | metafield_tag
			assign ref_content_stripped = ref_content | strip_html | strip
			assign ref_content_size = ref_content_stripped | size
			assign use_modal = false
			if ref_content_size > content_threshold
				assign use_modal = true
			endif
			assign modal_id = 'ref-modal-' | append: section.id | append: '-' | append: ref_index
		-%}

		{%- if use_modal -%}
			{%- capture ref_icon -%}
				{%- case ref_type -%}
					{%- when 'verpakkingsinformatie' -%}
						{%- render 'html-theme-icons', icon: 'package', size: 24 -%}
					{%- when 'leeftijdsverificatie' -%}
						{%- render 'html-theme-icons', icon: 'shield-check', size: 24 -%}
					{%- when 'productie' -%}
						{%- render 'html-theme-icons', icon: 'factory', size: 24 -%}
					{%- when 'onderhoud' -%}
						{%- render 'html-theme-icons', icon: 'wrench', size: 24 -%}
					{%- when 'afwerking' -%}
						{%- render 'html-theme-icons', icon: 'sparkles', size: 24 -%}
					{%- when 'kwaliteitsclassificatie' -%}
						{%- render 'html-theme-icons', icon: 'badge', size: 24 -%}
					{%- when 'materiaal' -%}
						{%- render 'html-theme-icons', icon: 'layers', size: 24 -%}
					{%- when 'garantie' -%}
						{%- render 'html-theme-icons', icon: 'shield', size: 24 -%}
					{%- when 'opmeten' -%}
						{%- render 'html-theme-icons', icon: 'ruler', size: 24 -%}
					{%- when 'verzending' -%}
						{%- render 'html-theme-icons', icon: 'truck', size: 24 -%}
					{%- when 'bevestiging' -%}
						{%- render 'html-theme-icons', icon: 'bolt', size: 24 -%}
					{%- else -%}
						{%- render 'html-theme-icons', icon: 'info', size: 24 -%}
				{%- endcase -%}
			{%- endcapture -%}

			<div
				class="block-product-information__modal"
				data-modal="{{ modal_id }}"
				role="dialog"
				aria-modal="true"
				aria-label="{{ ref_item.title }}"
				hidden
			>
				<div class="block-product-information__modal-overlay" data-modal-overlay></div>
				<div class="block-product-information__modal-content theme-modal__content">
					<header class="block-product-information__modal-header theme-modal__header">
						<h3 class="block-product-information__modal-title theme-modal__title">
							{{ ref_icon }}
							{{ ref_item.title }}
						</h3>
						<button type="button" class="block-product-information__modal-close theme-modal__close" data-modal-close aria-label="{{ 'accessibility.close' | t }}">
							{%- render 'html-theme-icons', icon: 'close', size: 24 -%}
						</button>
					</header>
					<div class="block-product-information__modal-body theme-modal__body">
						{{ ref_content }}
					</div>
				</div>
			</div>
		{%- endif -%}

		{%- assign ref_index = ref_index | plus: 1 -%}
	{%- endfor -%}
{%- endif -%}

{% schema %}
{
	"name": "Product information",
	"tag": "section",
	"class": "block-product-information",
	"limit": 1,
	"enabled_on": {
		"templates": ["product"]
	},
	"settings": [
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "text",
			"id": "description_heading",
			"label": "Description heading",
			"info": "Leave empty to use locale default"
		},
		{
			"type": "text",
			"id": "details_heading",
			"label": "Details heading",
			"info": "Leave empty to use locale default"
		},
		{
			"type": "text",
			"id": "sizechart_heading",
			"label": "Size chart heading",
			"info": "Leave empty to use locale default"
		},
		{
			"type": "text",
			"id": "read_more_text",
			"label": "Read more text",
			"info": "Leave empty to use locale default"
		},
		{
			"type": "text",
			"id": "read_less_text",
			"label": "Read less text",
			"info": "Leave empty to use locale default"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "width",
			"label": "Width",
			"options": [
				{ "value": "is-align-narrow", "label": "Narrow" },
				{ "value": "is-align-small", "label": "Small" },
				{ "value": "is-align", "label": "Regular" },
				{ "value": "is-align-wide", "label": "Wide" },
				{ "value": "is-align-full", "label": "Full" }
			],
			"default": "is-align"
		},
		{
			"type": "range",
			"id": "padding_block",
			"label": "Vertical padding",
			"min": 0,
			"max": 6,
			"step": 0.5,
			"default": 4,
			"unit": "em"
		},
		{
			"type": "text",
			"id": "anchor",
			"label": "Anchor ID",
			"default": "product-information",
			"info": "ID for scroll links (without #)"
		},
		{
			"type": "text",
			"id": "custom_class",
			"label": "Custom class",
			"info": "Add custom CSS class for styling"
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Text"
		},
		{
			"type": "header",
			"content": "Howto"
		},
		{
			"type": "paragraph",
			"content": "Displays product description, details, size chart, and information references from metafields (custom.product_details, custom.product-sizechart, custom.product-information-references)."
		}
	],
	"presets": [
		{
			"name": "Information",
			"category": "Product"
		}
	]
}
{% endschema %}
