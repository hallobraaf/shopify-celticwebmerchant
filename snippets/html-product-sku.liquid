{%- comment -%}
  ============================================================================
  HTML-PRODUCT-SKU
  ============================================================================
  Displays the product SKU (Stock Keeping Unit).

  PARAMETERS:
  - product: {Object} Product object (required)
  - show_label: {Boolean} Show "SKU:" label (default: true)
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign v = product.selected_or_first_available_variant
  if show_label == nil
    assign display_label = true
  else
    assign display_label = show_label
  endif
-%}

{%- if v.sku != blank -%}
  <div class="product-sku">
    {%- if display_label -%}
      <span class="product-sku__label">{{ 'product.sku' | t }}:</span>
    {%- endif -%}
    <span class="product-sku__value" data-sku>{{ v.sku }}</span>
  </div>
{%- endif -%}


