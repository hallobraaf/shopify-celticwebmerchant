{%- comment -%}
  ============================================================================
  HTML-BUTTON-ORDER
  ============================================================================

  Purpose:
  Renders an add-to-cart button (or link to PDP for variant-products) for
  quick-add contexts. Submit handling is delegated to the global CartAPI
  interceptor in theme-cart.js — this snippet only emits the form HTML and
  attaches the right data-cart-* attributes for the interceptor to read.

  Usage:
  {% render 'html-button-order', product: product %}
  {% render 'html-button-order', product: product, variant_behavior: 'link' %}
  {% render 'html-button-order', product: product, on_success: 'checked' %}

  Parameters:
  - product: {Object} Product object (required)
  - variant: {Object} Specific variant to add (optional, defaults to selected_or_first_available_variant)
  - quantity: {Number} Quantity to add (default: 1)
  - variant_behavior: {String} Behavior for products with variants:
      - 'link': Link to product page so customer can choose (DEFAULT).
        This is the right default because the theme has no quick variant
        picker on cards — without one, "add" would blind-add the default
        variant which is rarely what the customer wanted.
      - 'add':  Always add selected variant directly. Pass explicitly when
        you DO want blind-add (e.g., on a context where the variant choice
        is already made elsewhere).
  - on_success: {String} Post-add behavior, drives data-cart-on-success.
      One of: 'preview' | 'confirmation' | 'checked' | 'page'.
      Default: settings.cart_type. Pass 'checked' explicitly to suppress
      drawer-opening (e.g., quick-add inside cart-confirm drawer to avoid
      recursive reopen). Pass 'page' to skip AJAX entirely (native submit).
  - show_icon: {Boolean} Show cart icon (default: true)
  - class: {String} Additional CSS classes (optional)
  - button_style: {String} 'primary' | 'secondary' | 'minimal' (default: 'primary')

  How submission flows:
  1. User clicks submit → submit event bubbles to document
  2. theme-cart.js's interceptor reads data-cart-ajax (skip if absent)
  3. Interceptor reads data-cart-on-success and data-product-handle
  4. AJAX add via CartAPI.add(); button-state classes (is-loading/success/error)
     are applied universally by the interceptor
  5. On success the interceptor dispatches to CartPreview / CartConfirm based
     on on_success. 'checked' = no drawer, vinkje on the button is the feedback.

  Dependencies:
  - html-theme-icons snippet
  - theme-cart.js (CartAPI.interceptForms is auto-activated on DOMContentLoaded)

  ============================================================================
{%- endcomment -%}

{%- liquid
  assign p = product
  assign v = variant | default: p.selected_or_first_available_variant
  assign qty = quantity | default: 1
  assign variant_behavior = variant_behavior | default: 'link'
  assign on_success = on_success | default: settings.cart_type
  assign show_icon = show_icon | default: true
  assign additional_class = class | default: ''
  assign button_style = button_style | default: 'primary'

  assign has_variants = false
  if p.variants.size > 1
    assign has_variants = true
  endif

  assign should_link = false
  if has_variants and variant_behavior == 'link'
    assign should_link = true
  endif

  comment
    AJAX is enabled for all on_success values except 'page'.
    'page' explicitly opts out → native form submit, browser redirects to /cart.
  endcomment
  assign use_ajax = true
  if on_success == 'page'
    assign use_ajax = false
  endif

  assign unique_id = p.id | append: '-' | append: 'now' | date: '%s%N'
-%}

{%- if p.available -%}
  {%- if should_link -%}
    <a 
      href="{{ p.url }}"
      class="button-order button-order--{{ button_style }} {{ additional_class }}"
    >
      {%- if show_icon -%}
        <span class="button-order__icon" aria-hidden="true">
          {%- render 'html-theme-icons', icon: 'plus', size: 20 -%}
        </span>
      {%- endif -%}
      <span class="button-order__text">
        {{ 'product.choose_options' | t }}
      </span>
    </a>
  {%- else -%}
    <form
      method="post"
      action="{{ routes.cart_add_url }}"
      class="button-order__form"
      data-button-order-form="{{ unique_id }}"
      {% if use_ajax %}
        data-cart-ajax
        data-cart-on-success="{{ on_success }}"
        data-product-handle="{{ p.handle }}"
      {% endif %}
    >
      <input type="hidden" name="id" value="{{ v.id }}">
      <input type="hidden" name="quantity" value="{{ qty }}">
      
      <button 
        type="submit"
        class="button-order button-order--{{ button_style }} {{ additional_class }}"
        data-button-order-add
      >
        {%- if show_icon -%}
          <span class="button-order__icon" aria-hidden="true">
            {%- render 'html-theme-icons', icon: 'cart-add', size: 20 -%}
          </span>
        {%- endif -%}
        <span class="button-order__text" data-button-text>
          {{ 'product.add_to_cart' | t }}
        </span>
        <span class="button-order__badge button-order__badge--success" data-button-success aria-label="{{ 'cart.item_added' | t }}">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        </span>
        <span class="button-order__badge button-order__badge--error" data-button-error aria-label="{{ 'error.general' | t }}">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </span>
      </button>
    </form>
    {%- comment -%}
      No inline submit handler. The global CartAPI.interceptForms() in
      theme-cart.js reads data-cart-ajax / data-cart-on-success on this
      form and handles the entire flow: AJAX add, button states (is-loading
      / is-success / is-error which the CSS below already styles), and
      drawer dispatch. Forms without data-cart-ajax (on_success='page')
      submit natively — browser redirects to /cart.
    {%- endcomment -%}
  {%- endif -%}

{%- else -%}
  <span 
    class="button-order button-order--soldout {{ additional_class }}"
    aria-disabled="true"
  >
    <span class="button-order__text">
      {{ 'product.sold_out' | t }}
    </span>
  </span>
{%- endif -%}

<style>
  .button-order {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 0.75em 1.25em;
    font-family: inherit;
    font-size: inherit;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background-color 200ms ease, opacity 200ms ease, transform 100ms ease;
  }

  .button-order:active {
    transform: scale(0.98);
  }

  .button-order__form {
    display: contents;
  }

  .button-order--primary {
    background-color: var(--theme-color-green, #000);
    color: var(--theme-color-white, #fff);
  }

  .button-order--primary:hover {
    opacity: 0.9;
  }

  .button-order--secondary {
    background-color: transparent;
    color: inherit;
    border: 1px solid currentColor;
  }

  .button-order--secondary:hover {
    background-color: var(--theme-color-foreground, #000);
    color: var(--theme-color-background, #fff);
  }

  .button-order--minimal {
    background-color: transparent;
    color: inherit;
    padding: 0.5em;
  }

  .button-order--minimal:hover {
    opacity: 0.7;
  }

  .button-order--soldout {
    background-color: var(--theme-color-grey-light, #f5f5f5);
    color: var(--theme-color-grey, #666);
    cursor: not-allowed;
    opacity: 0.7;
  }

  .button-order__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .button-order__text {
    font-size: 0.8em;
  }

  .button-order__badge {
    display: none;
    position: absolute;
    top: -0.4em;
    right: -0.4em;
    width: 1.4em;
    height: 1.4em;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: #fff;
    pointer-events: none;
    z-index: 1;
  }

  .button-order__badge--success { background-color: var(--theme-color-green, #4caf50); }
  .button-order__badge--error { background-color: var(--theme-color-red, #f44336); }

  .button-order.is-loading { pointer-events: none; opacity: 0.6; }

  .button-order.is-success [data-button-success] { display: flex; }
  .button-order.is-error [data-button-error] { display: flex; }
</style>
