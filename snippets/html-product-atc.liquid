            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
      </button>

    </div> -->
</div>

<script>
  // Quantity buttons (event delegation)
  document.addEventListener('click', (e) => {
    const minus = e.target.closest('[data-qty-minus]');
    const plus = e.target.closest('[data-qty-plus]');
    if (!minus && !plus) return;
    
    const wrapper = (minus || plus).closest('.product-atc__quantity');
    const input = wrapper?.querySelector('[data-qty-input]');
    if (!input) return;
    
    const current = parseInt(input.value, 10) || 1;
    const min = parseInt(input.min, 10) || 1;
    
    if (minus && current > min) {
      input.value = current - 1;
    } else if (plus) {
      input.value = current + 1;
    }
    
    input.dispatchEvent(new Event('change', { bubbles: true }));
  });

  // Update variant IDs on app buttons when variant changes
  document.addEventListener('product:updated', (e) => {
    const { variantId } = e.detail;
    if (!variantId) return;
    
    const wrapper = e.target.closest('[data-product-form]');
    if (!wrapper) return;
    
    // Update data attributes on notify and wishlist buttons
    wrapper.querySelectorAll('[data-atc-notify] [data-variant-id], [data-atc-wishlist] [data-variant-id]').forEach(el => {
      el.dataset.variantId = variantId;
    });
  });
</script>

