{%- comment -%}
  ============================================================================
  HTML-PRODUCT-ATC
  ============================================================================
  Add to cart button with optional inline quantity input and wishlist.

  PARAMETERS:
  - product: {Object} Product object (required)
  - full_width: {Boolean} Full width button (default: true)
  - show_quantity: {Boolean} Show quantity input (default: true)
  - show_wishlist: {Boolean} Show wishlist button (default: true)

  FEATURES:
  - Inline quantity selector
  - Submit button with sold out/unavailable states
  - Data attributes for JS state updates
  - Wishlist integration (third-party app)
  
  STRUCTURE:
  - Container: flex row with 3 sibling divs
  - [data-fragment-update="atc"] wraps quantity + button (updated on variant change)
  - Notify and wishlist are siblings (preserved across updates)
  - CSS uses .is-available class + sibling selectors for visibility
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign v = product.selected_or_first_available_variant
  if full_width == nil
    assign is_full_width = true
  else
    assign is_full_width = full_width
  endif
  if show_quantity == nil
    assign display_quantity = true
  else
    assign display_quantity = show_quantity
  endif
  if show_wishlist == nil
    assign display_wishlist = true
  else
    assign display_wishlist = show_wishlist
  endif
  
  assign is_available = false
  if v.available
    assign is_available = true
  endif
  
  assign atc_label = 'product.add_to_cart' | t
  assign sold_out_label = 'product.sold_out' | t
  assign unavailable_label = 'product.unavailable' | t
-%}

<div class="product-atc" data-product-atc>
  {%- comment -%} Form: quantity + button (fragment updated) {%- endcomment -%}
  <div class="product-atc__form{% if is_available %} is-available{% endif %}" data-fragment-update="atc">
    {%- if display_quantity -%}
      <div class="product-atc__quantity">
        <button 
          type="button" 
          class="product-atc__qty-btn" 
          data-qty-minus 
          aria-label="{{ 'product.quantity.decrease' | t }}"
        >
          <span aria-hidden="true">−</span>
        </button>
        <input 
          type="number" 
          name="quantity" 
          class="product-atc__qty-input" 
          value="1" 
          min="1" 
          aria-label="{{ 'product.quantity.label' | t }}"
          data-qty-input
        >
        <button 
          type="button" 
          class="product-atc__qty-btn" 
          data-qty-plus 
          aria-label="{{ 'product.quantity.increase' | t }}"
        >
          <span aria-hidden="true">+</span>
        </button>
      </div>
    {%- endif -%}

    <button 
      type="submit"
      class="product-atc__btn{% if is_full_width %} product-atc__btn--full{% endif %}"
      data-atc
      {% unless v.available %}disabled{% endunless %}
    >
      <span data-atc-text>
        {%- if v.available -%}
          {{ atc_label }}
        {%- else -%}
          {{ sold_out_label }}
        {%- endif -%}
      </span>
    </button>
  </div>

  {%- comment -%} Notify: back in stock (sibling, not updated) {%- endcomment -%}
  <!-- <div class="product-atc__notify" data-atc-notify>
    <a 
      id="custom-notify-button" 
