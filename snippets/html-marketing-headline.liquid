{%- comment -%}
============================================================================
HTML-MARKETING-HEADLINE
============================================================================
Reusable headline component for marketing sections.

PARAMS:
- heading       : Main heading text (required)
- subheading    : Optional subheading text
- heading_tag   : HTML tag h1-h6 (default: h2)
- alignment     : left | center | right (default: center)
- size          : small | medium | large (default: medium)

USAGE:
{%- render 'html-marketing-headline',
    heading: section.settings.heading,
    subheading: section.settings.subheading,
    alignment: 'center',
    size: 'large'
-%}

STYLING:
Sections can override with scoped CSS:
#shopify-section-{{ section.id }} .marketing-headline__heading { ... }
============================================================================
{%- endcomment -%}

{%- liquid
	assign heading = heading | default: ''
	assign subheading = subheading | default: ''
	assign heading_tag = heading_tag | default: 'h2'
	assign alignment = alignment | default: 'center'
	assign size = size | default: 'medium'
-%}

{%- if heading != blank -%}
<header class="marketing-headline marketing-headline--{{ size }} marketing-headline--align-{{ alignment }}">
	<{{ heading_tag }} class="marketing-headline__heading">{{ heading | escape }}</{{ heading_tag }}>
	{%- if subheading != blank -%}
		<p class="marketing-headline__subheading">{{ subheading | escape }}</p>
	{%- endif -%}
</header>
{%- endif -%}

