    "block_marketing_features_xKmArY": {
      "type": "block-marketing-features",
      "name": "Betrouwbaarheid & transparantie",
      "settings": {
        "heading": "Betrouwbaarheid & transparantie",
        "subheading": "",
        "text": "<p>Bij Celtic WebMerchant combineren we passie met professionaliteit:</p><ul><li><strong>Volledig legaal en geregistreerd bedrijf</strong>: KvK 87703211, BTW NL864375803B01, EORI NL864375803<br/></li><li><strong>Internationale aanwezigheid</strong>: 15 webwinkels in Europa en wereldwijd<br/></li><li><strong>Transparant en eerlijk team</strong>: Onze medewerkers, modellen en tijdelijke krachten worden altijd eerlijk betaald.<br/></li><li><strong>Inclusief en divers</strong>: Driekwart van ons team is neurodivers, met speciale aandacht voor mensen met ADHD en autisme.<br/></li></ul><p><br/>Bekijk ons <a href=\"/pages/portfolio\" title=\"Portfolio – Historische Reconstructies en Costuming\">portfolio</a> met samenwerkingen met musea, filmproducties en organisaties wereldwijd.<br/><br/></p>",
        "width": "is-align",
        "columns_desktop": 3,
        "columns_tablet": 2,
        "columns_mobile": 1,
        "alignment": "center",
        "icon_style": "circle",
